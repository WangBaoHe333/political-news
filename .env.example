# 时政系统环境变量配置

# === 数据库配置 ===
# 默认使用SQLite，如需使用其他数据库请修改
# SQLite: sqlite:///./political_news.db
# PostgreSQL: postgresql://user:password@localhost/dbname
# MySQL: mysql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./political_news.db

# === 应用配置 ===
# 启动时自动同步：0=禁用，1=启用（建议首次启动后禁用）
AUTO_SYNC_ON_STARTUP=0

# 同步抓取限制（防止内存溢出）
SYNC_MAX_PAGES=260      # 最大抓取页数（默认260页，约2年数据）
SYNC_MAX_ITEMS=400      # 最大抓取条目数

# HTTP请求配置
HTTP_TIMEOUT_SECONDS=30  # HTTP请求超时时间（秒）
HTTP_RETRIES=2           # 失败重试次数

# === 数据源配置（通常不需要修改） ===
# 中国政府网时政新闻列表
LIST_BASE_URL=https://www.gov.cn/yaowen/
LIST_JSON_URL=https://www.gov.cn/yaowen/liebiao/YAOWENLIEBIAO.json
LIST_ARCHIVE_BASE_URL=https://www.gov.cn/yaowen/liebiao/

# === 定时任务配置 ===
# 定时同步间隔（小时），设置0禁用定时同步
SYNC_INTERVAL_HOURS=6

# === 分批回填配置 ===
BACKFILL_BATCH_SIZE=3    # 每次处理的月份数
BACKFILL_MAX_ITEMS=150   # 每批最大条目数

# === 日志配置 ===
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === 服务器配置 ===
# 服务器绑定地址和端口
HOST=0.0.0.0
PORT=8000

# === 安全配置 ===
# CORS允许的源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === 功能开关 ===
# 启用AI功能：0=禁用，1=启用（禁用后使用基础总结和题目）
ENABLE_AI_FEATURES=1

# 启用定时任务：0=禁用，1=启用
ENABLE_SCHEDULED_TASKS=1
