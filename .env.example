# 时政系统环境变量示例

# 数据库
DATABASE_URL=sqlite:///./political_news.db

# 启动行为
# AUTO_SYNC_ON_STARTUP=1 会在每次服务启动时强制抓取近两年内容
AUTO_SYNC_ON_STARTUP=0
# BOOTSTRAP_RECENT_NEWS_ON_STARTUP=1 会在数据库缺少近两年数据时自动补齐
BOOTSTRAP_RECENT_NEWS_ON_STARTUP=1
# 正式环境建议设置，用于保护手动同步接口
SYNC_ADMIN_TOKEN=

# 部署访问地址
CORS_ORIGINS=http://localhost:8000
