# Political News environment example
# Copy to `.env` (local dev) or `.env.production` (server runtime).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Non-Docker deployment (recommended on lightweight VPS): SQLite
DATABASE_URL=sqlite:///./political_news.db

# Docker deployment with Compose + postgres service example:
# DATABASE_URL=postgresql://postgres:your_password@postgres:5432/political_news

# -----------------------------------------------------------------------------
# Sync behavior
# -----------------------------------------------------------------------------
# Run quick startup sync for recent data
AUTO_SYNC_ON_STARTUP=1

# If DB is missing recent 24-month coverage, run bootstrap backfill on startup
BOOTSTRAP_RECENT_NEWS_ON_STARTUP=1

# Scheduled sync interval in hours. 1 = hourly.
SCHEDULED_SYNC_INTERVAL_HOURS=1

# Always use Beijing time for scheduler and status display
SCHEDULED_SYNC_TIMEZONE=Asia/Shanghai

# -----------------------------------------------------------------------------
# Security / operations
# -----------------------------------------------------------------------------
# Set a strong random token in production to protect /sync and /backfill routes
SYNC_ADMIN_TOKEN=replace_with_a_long_random_token

# Expose docs in dev, hide in production
EXPOSE_API_DOCS=1

# TLS verification for source fetching (keep enabled in production)
HTTP_VERIFY_TLS=1

# Optional CORS
CORS_ORIGINS=http://localhost:8000
